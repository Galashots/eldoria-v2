{
  "name": "eldoria-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Realm of Eldoria v2 - Phaser + Vite + Tiled educational RPG prototype.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "smoke": "playwright test",
    "check": "npm run validate:visual-targets && npm run typecheck && npm run build && npm run test:pwa && npm run test:generated-surfaces",
    "validate:visual-targets": "node scripts/validate-visual-targets.mjs",
    "normalize:asset": "node scripts/normalize-asset-sheet.mjs",
    "validate:asset": "node scripts/validate-asset-sheet.mjs",
    "compose:terrain-blend": "node scripts/compose-terrain-blend-family.mjs",
    "test:terrain-blend": "node scripts/test-terrain-blend-compositor.mjs",
    "compose:terrain-proof": "node scripts/compose-terrain-proof-tileset.mjs",
    "test:asset-pipeline": "node scripts/test-asset-pipeline.mjs",
    "review:asset": "node scripts/review-asset.mjs",
    "test:asset-review": "node scripts/test-asset-review.mjs",
    "review:contact-sheet": "node scripts/build-review-contact-sheet.mjs",
    "test:contact-sheet": "node scripts/test-review-contact-sheet.mjs",
    "test:visual-targets": "node scripts/test-visual-targets.mjs",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "test:pwa": "node scripts/test-pwa-manifest.mjs",
    "test:generated-surfaces": "npm run generate:pwa-icons && npm run compose:terrain-proof && git diff --exit-code -- public/icons public/assets/tilesets/farm-terrain-proof.png public/maps/farm.json",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.8.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
