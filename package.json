{
  "name": "eldoria-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Realm of Eldoria v2 - Phaser + Vite + Tiled educational RPG prototype.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "smoke": "playwright test",
    "check": "npm run validate:visual-targets && npm run typecheck && npm run build",
    "validate:visual-targets": "node scripts/validate-visual-targets.mjs"
  },
  "dependencies": {
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.8.0",
    "vite": "^8.1.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
